# API server (local dev — docker compose up for Postgres)
#
# Self-hosted production (customer VPS, no Railway):
#   cp .env.production.example .env.production
#   docker compose -f ../docker-compose.prod.yml up -d --build
#   docs/DEPLOY.md §셀프호스팅 — migrate:prod runs in api/Dockerfile on boot;
#   first admin: npm run create-admin (see DEPLOY.md)
PORT=3000
APP_ENV=development

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgresql://topik:topik_dev@localhost:5432/topik_mm_dev

# JWT (generate strong secrets for staging/prod)
JWT_SECRET=dev-change-me-access-secret
JWT_REFRESH_SECRET=dev-change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS — comma-separated origins (no wildcard in prod)
CORS_ORIGINS=http://localhost:5500,http://localhost:8080,http://127.0.0.1:5500,http://127.0.0.1:8080,https://topik-myanmar.vercel.app

# Public FO origin used to build links inside emails (password reset, etc.)
PUBLIC_FO_BASE=http://localhost:8080
# Optional BO origin for operator notification links
# PUBLIC_BO_BASE=http://localhost:8080/admin
# Support email in template footers
# MAIL_SUPPORT=topik.myanmar@koica.go.kr
# Operator inbox for board_admin_new_post (leave blank to skip admin alerts in dev)
# MAIL_ADMIN_TO=ops@example.com
# Internal API key for POST /internal/notifications/* (blank = open in development)
# INTERNAL_API_KEY=
# Optional daily batch for users who rarely log in (default: login hook only)
# ENABLE_PASSWORD_EXPIRY_CRON=false
# Background email_outbox drain worker — retries queued/failed sends every 30s
# (batch 25, max 5 retries). Default OFF: emails send inline as today. Turn ON
# to make marketing bulk sends enqueue-only + drained by the worker.
# ENABLE_EMAIL_WORKER=false

# File / photo storage — provider = local (dev: disk) | s3
# local (default): decoded photos saved under UPLOAD_DIR, served via GET /api/v1/files/:id.
#   No credentials needed — signup/profile/application photos work locally out of the box.
STORAGE_PROVIDER=local
# Local disk root (relative paths resolve against api/). gitignore'd; created on first upload.
UPLOAD_DIR=var/uploads
# Max accepted decoded image size in bytes (default 5MB).
# UPLOAD_MAX_BYTES=5242880
# S3 (or S3-compatible): set STORAGE_PROVIDER=s3 + the 4 required vars below.
# If any required var is missing, the server logs a warning and falls back to local.
# S3_BUCKET=topik-mm-photos
# S3_REGION=ap-southeast-1
# S3_ACCESS_KEY=
# S3_SECRET=
# S3_ENDPOINT=            # optional — MinIO / non-AWS S3-compatible endpoint
# S3_PREFIX=photos        # optional — key prefix inside the bucket

# Google Sign-In (Google Identity Services). Leave BLANK to keep the feature OFF:
#   GET  /api/v1/auth/google/config → {"enabled":false}  (FO hides the button)
#   POST /api/v1/auth/google         → 503 oauth_not_configured
# To enable: Google Cloud Console → APIs & Services → Credentials →
#   "OAuth client ID" (type: Web application). Add Authorized JavaScript origins
#   for every FO origin (e.g. http://localhost:8080, https://topik-myanmar.vercel.app).
#   GIS uses ID tokens (no redirect URI required for this flow).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Mailer — provider = console (dev: logs only, NO send) | smtp | resend
# Dev default "console" keeps signup + password reset fully working with no creds:
#   send-verification-code returns dev_code; request-password-reset returns dev_reset_token.
MAIL_PROVIDER=console
MAIL_FROM=TOPIK Myanmar <no-reply@topik-mm.local>
# Resend (simplest to go live — only needs an API key): MAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxx
# SMTP (alternative): MAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=xxx
