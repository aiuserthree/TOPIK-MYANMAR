\'a0 \uc0\u12615  \u47196 \u44536 \u51064  \u54596 \u49688 ,  \u49457 \u47749 /\u49373 \u45380 \u50900 \u51068  \u51077 \u47141 \u51008  \u51221 \u48372  \u54869 \u51064 \u51012  \u50948 \u54644  \u50976 \u51648 \
