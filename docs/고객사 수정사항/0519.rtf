# FO\
(\uc0\u49884 \u54744  \u51217 \u49688 )\'a0\
\'a0\uc0\u12615  \u47196 \u44536 \u51064  \u44428 \u51109  \u8594  \u54596 \u50836 \
\'a0\uc0\u12615  \u51652 \u54665  \u55120 \u47492  :\'a0\
\'a0 \'a0- Step1 : \uc0\u54924 \u52264 \u50752  \u44553 \u49688 \u47484  \u54632 \u44760  \u49440 \u53469  (TOPIK 1,2 \u46041 \u49884 \u51217 \u49688 \u54616 \u45716  \u44221 \u50864  \u51316 \u51116 )\
\'a0 \'a0- Step2 : \uc0\u54924 \u50896 \u51221 \u48372 \u47196 \u47564  \u51217 \u49688  \u44032 \u45733 , \u52628 \u44032  \u51221 \u48372 \u48320 \u44221  \u48520 \u44032 \
\'a0 \'a0- Step3 : \uc0\u51088 \u46041 \u51452 \u51077 \u46104 \u45716  \u54924 \u50896 \u51221 \u48372 \u49345  \u49324 \u51652 \u47564  \u49324 \u50857  \u44032 \u45733 \u54616 \u44256 , \u52628 \u44032 \u47196  \u49324 \u51652  \u50629 \u47196 \u46300 \u45716  \u48520 \u44032 \'a0/ \u44508 \u44201 \u50640  \u47582 \u45716 \u51648  \u54869 \u51064 \u47564 \'a0\u54616 \u45716  \u51208 \u52264 \
\'a0 \uc0\u12615  \u51228 \u52636  \u54980  \u50504 \u45236  \u47704 \u53944  \u49688 \u51221 \'a0: "\u49324 \u51652  \u49900 \u49324  \u48143  \u50724 \u54532 \u46972 \u51064  \u51025 \u49884 \u47308  \u49688 \u45225  \u54980  \u49688 \u54744 \u48264 \u54840 \u44032  \u48512 \u50668 \u46121 \u45768 \u45796 . \u44288 \u47144  \u51068 \u51221  \u48143  \u50976 \u51032 \u49324 \u54637 \u51008  \u44277 \u51648 \u49324 \u54637 \u51012  \u52280 \u44256 \u54616 \u49884 \u44592  \u48148 \u46989 \u45768 \u45796 . \u51217 \u49688  \u44208 \u44284 \u45716  \u47560 \u51060 \u54168 \u51060 \u51648 \u50640 \u49436  \u54869 \u51064 \u54616 \u49884 \u44592  \u48148 \u46989 \u45768 \u45796 .\
