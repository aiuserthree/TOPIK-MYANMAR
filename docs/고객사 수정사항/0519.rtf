# BO\'a0\
(\uc0\u44277 \u53685 )\
\uc0\u12615  \u50864 \u49440  \u50668 \u47084  \u47749 \u50640 \u44172  \u48324 \u46020  \u50500 \u51060 \u46356 \u47484  \u48512 \u50668 \u54616 \u50668  \u46041 \u49884 \u50640  \u51217 \u49549 \u54624  \u49688  \u51080 \u50632 \u51004 \u47732  \u51339 \u44192 \u49845 \u45768 \u45796 ! -> \u44288 \u47532 \u51088  \u44228 \u51221  \u44288 \u47532  \u47700 \u45684  \u49888 \u49444 \
\
(\uc0\u51217 \u49688 \u44288 \u47532 )\
\uc0\u12615  \u50724 \u54532 \u46972 \u51064  \u49688 \u45225  \u52376 \u47532  :\'a0\u49345 \u44592  \u46041 \u49884 \u51217 \u49549 \u44284  \u44057 \u51008  \u47589 \u46973 \u51064 \u45936 , \u53945 \u55176  \u49688 \u45225 \u52376 \u47532 \u49884 \u50640 \'a0\u50668 \u47084  \u48516 \u51060  \u46041 \u49884 \u50640  \u51089 \u50629 \u54616 \u49888 \u45796 \u44256  \u46308 \u50612 \u49436  \u46041 \u49884 \u50640  \u51089 \u50629 \u54624  \u49688  \u51080 \u51004 \u47732  \u51339 \u44192 \u49845 \u45768 \u45796 . \u45796 \u47564  \u50500 \u51060 \u46356 \u48324  \u49688 \u51221  \u51060 \u47141 \u51012  \u54869 \u51064 \u54624  \u49688  \u51080 \u45796 \u47732  \u51339 \u51012  \u44163  \u44057 \u49845 \u45768 \u45796 . -> \u44288 \u47532 \u51088  \u49688 \u51221 /\u52376 \u47532  \u51060 \u47141  \u47700 \u45684  \u49888 \u49444 \
\uc0\u12615  \u49688 \u54744 \u48264 \u54840  \u48512 \u50668 \'a0: \u51221 \u54644 \u51652  \u50896 \u52825 \u51060  \u51080 \u45716 \u45936  \u48152 \u50689 \u51060  \u46112 \u44620 \u50836 ? \u50500 \u47000  \u52280 \u44256  \u48512 \u53441 \u46300 \u47549 \u45768 \u45796 . \u50500 \u50872 \u47084  \u46041 \u51068 \u51064 \u51060  \u53664 \u54589  1(\u50724 \u51204 ),2(\u50724 \u54980 )\u47484  \u46041 \u49884  \u51217 \u49688 \u54616 \u45716  \u44221 \u50864 \u44032  \u51080 \u50612 \u49436 , \u44536  \u44221 \u50864 \u50640 \u45716  \u46041 \u51068 \u54620  \u49884 \u54744 \u51109 \u50640 \u49436  \u51025 \u49884 \u54624  \u49688  \u51080 \u46020 \u47197  \u46041 \u51068 \u54620  \u49884 \u54744 \u51109  \u53076 \u46300 \u47484  \u48512 \u50668 \u54664 \u51004 \u47732  \u54633 \u45768 \u45796 . -> \u49688 \u54744 \u48264 \u54840  \u48512 \u50668  \u50504 \u45236  \u47928 \u49436 (\u50641 \u49472 ) \u52280 \u44256 \
\uc0\u12615  \u50641 \u49472  \u45236 \u48372 \u45236 \u44592  : \u45796 \u50868 \u47196 \u46300 \u46104 \u45716  \u54028 \u51068 \u51060  \u48537 \u51076  \u50641 \u49472 \u54028 \u51068 (~~ \u44397 \u50808  \u51648 \u50896 \u51088  \u50672 \u47749 \u48512 )\u44284  \u46041 \u51068 \u54620  \u50577 \u49885 \u51060 \u47732  \u51339 \u51012  \u44163  \u44057 \u49845 \u45768 \u45796 (\u50500 \u47000  \u49324 \u51652 \u46020  \u52280 \u51312 ). \u46384 \u46972 \u49436  \u52972 \u47100 \u50640 \u46020  \u50672 \u46973 \u52376 /\u51060 \u47700 \u51068 \u51008  \u48520 \u50836 \u54633 \u45768 \u45796 . \u44592 \u50773 \u51060 \u47732  \u51228 \u47785 \u46020  (\u54924 \u52264 ) TOPIK \u51648 \u50896 \u51088  \u50672 \u47749 \u48512 (\u44397 \u44032 _\u49884 \u54744 \u51109 )\u51004 \u47196  \u45796 \u50868 \u47196 \u46300 \u54624  \u49688  \u51080 \u51012 \u44620 \u50836 ? \u50696 \u47484 \u46308 \u47732  \u51228 106\u54924  TOPIK \u51648 \u50896 \u51088  \u50672 \u47749 \u48512 (\u48120 \u50560 \u47560 _\u50577 \u44260 \u45824  \u55128 \u46972 \u51081 \u52896 \u54140 \u49828 ) \u52376 \u47100 \u50836  -> \u50672 \u47749 \u48512  \u50577 \u49885  \u47928 \u49436 (\u50641 \u49472 ) \u52280 \u44256 \
\uc0\u12615  \u49324 \u51652  \u51068 \u44292  \u45796 \u50868 \u47196 \u46300 \'a0: \u48537 \u51076  \u50641 \u49472 \u54028 \u51068 \u51032  \u46160  \u48264 \u51704  \u53485 \u50640  \u45208 \u50752  \u51080 \u51648 \u47564 , \u51648 \u50896 \u51088 \u51032  \u49324 \u51652 \u54028 \u51068 \u51012  \u51648 \u50669 /\u49884 \u54744 \u51109 /\u49688 \u51456 \u48324  \u54260 \u45908 \u47196  \u50517 \u52629 \u54616 \u50668  \u51228 \u52636 \u54644 \u50556  \u54633 \u45768 \u45796 . \u51060 \u48120 \u51648  \u54028 \u51068 \u47749 \u51008  \u49688 \u54744 \u48264 \u54840 \u47564 \'a0\u44592 \u51116 , \u54805 \u49885 \u51008  jpg\u50668 \u50556  \u54616 \u44256 \u50836 .. \u51060 \u44163 \u46020  \u54620 \u48264 \u50640  \u45796 \u50868 \u47196 \u46300 \u48155 \u51012  \u49688  \u51080 \u46020 \u47197  \u48152 \u50689 \u51060  \u44032 \u45733 \u54624 \u44620 \u50836 ? -> \u50672 \u47749 \u48512  \u48143  \u49324 \u51652 \u51228 \u52636  \u50504 \u45236  \u47928 \u49436 (\u50641 \u49472 ) \u52280 \u44256 \
