[Unit]
Description=TOPIK Myanmar FastAPI (apps/api)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/topik-myanmar/apps/api
EnvironmentFile=/opt/topik-myanmar/apps/api/.env
ExecStart=/opt/topik-myanmar/apps/api/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
