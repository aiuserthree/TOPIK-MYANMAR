APP_ENV=development
DEBUG=false
DATABASE_URL=postgresql+asyncpg://topik_app:change_me@127.0.0.1:5432/topik_myanmar
JWT_SECRET=change-this-to-a-long-random-secret
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8081,http://127.0.0.1:8080,http://127.0.0.1:8081,https://www.topik-myanmar.com,https://admin.topik-myanmar.com

# File / photo storage — provider = local (dev) | s3 (IwinV Object Storage, 운영)
# local: var/uploads 에 저장, storage_key = local:{uuid}
# s3: Private 버킷(IwinV), 공개 URL 없음 — GET /files/:id API 프록시로만 제공
#     storage_key = s3:{bucket}/{S3_PREFIX}/photos|uploads/{uuid}
STORAGE_PROVIDER=local
UPLOAD_DIR=var/uploads
UPLOAD_MAX_BYTES=5242880

# IwinV S3-compatible Object Storage (docs/IWINV_SETUP.md §5) — STORAGE_PROVIDER=s3 일 때 필수
# S3_BUCKET=topik-myanmar-photos
# S3_REGION=kr-standard
# S3_ACCESS_KEY=          # IwinV 콘솔 인증키 (Git·슬랙에 올리지 않음)
# S3_SECRET=              # Secret Key
# S3_ENDPOINT=https://kr.object.iwinv.kr
# S3_PREFIX=photos        # 객체 키 prefix (예: photos/photos/{uuid}, photos/uploads/{uuid})

# Mail — provider = console (dev: logs only) | smtp (IwinV 테라웹메일 운영) | resend (대안)
MAIL_PROVIDER=console
MAIL_FROM=TOPIK Myanmar <noreply@topik-myanmar.com>
PUBLIC_FO_BASE=https://www.topik-myanmar.com
MIN_SIGNUP_AGE_YEARS=14

# 운영 (IwinV 테라웹메일 SMTP) — docs/IWINV_SETUP.md §6
# MAIL_PROVIDER=smtp
# SMTP_HOST=mail.topik-myanmar.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@topik-myanmar.com
# SMTP_PASS=terra_webmail_account_password
# ENABLE_EMAIL_WORKER=true

# 대안 (Resend API)
# MAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxx
