APP_ENV=development
DEBUG=false
# 운영: APP_ENV=production, DEBUG=false (localhost CORS regex 비활성, dev_code 미노출)
DATABASE_URL=postgresql+asyncpg://topik_app:change_me@127.0.0.1:5432/topik_myanmar
JWT_SECRET=change-this-to-a-long-random-secret
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8081,http://127.0.0.1:8080,http://127.0.0.1:8081,https://www.topik-myanmar.com,https://admin.topik-myanmar.com

# File / photo storage — 로컬·운영 모두 IwinV S3 (STORAGE_PROVIDER=s3)
# Private 버킷, 공개 URL 없음 — GET /files/:id API 프록시로만 제공
# storage_key = s3:{bucket}/{S3_PREFIX}/photos|uploads/{uuid}
STORAGE_PROVIDER=s3
UPLOAD_DIR=var/uploads
UPLOAD_MAX_BYTES=5242880

# IwinV S3-compatible Object Storage (docs/IWINV_SETUP.md §5) — 필수
# 필수값 누락 시 API 시작 실패. APP_ENV=development 에서 S3 업로드 실패 시 var/uploads 로컬 폴백.
# 운영(APP_ENV=production)은 유효한 IwinV 인증키 없이 업로드하면 400 오류로 명확히 실패합니다.
S3_BUCKET=topik-myanmar-photos
S3_REGION=kr-standard
S3_ACCESS_KEY=          # IwinV 콘솔 인증키 (Git·슬랙에 올리지 않음)
S3_SECRET=              # Secret Key
S3_ENDPOINT=https://kr.object.iwinv.kr
S3_PREFIX=photos        # 객체 키 prefix (예: photos/photos/{uuid}, photos/uploads/{uuid})

# (선택) 로컬 MinIO — Docker 필요, 기본 경로 아님. IwinV 대신 테스트할 때만.
# cd apps/api && docker compose -f docker-compose.minio.yml up -d
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET=minioadmin

# Mail — provider = console (dev: logs only) | smtp (IwinV 테라웹메일 운영)
MAIL_PROVIDER=console
MAIL_FROM=TOPIK Myanmar <noreply@topik-myanmar.com>
PUBLIC_FO_BASE=https://www.topik-myanmar.com
MIN_SIGNUP_AGE_YEARS=14

# Google OAuth (FO 간편가입/로그인) — GIS client ID from Google Cloud Console
# GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=   # optional; ID token verification uses client_id only

# 운영 (IwinV 테라웹메일 SMTP) — docs/IWINV_SETUP.md §6
# MAIL_PROVIDER=smtp
# SMTP_HOST=mail.topik-myanmar.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@topik-myanmar.com
# SMTP_PASS=terra_webmail_account_password
# ENABLE_EMAIL_WORKER=true

# --- 운영(IwinV) 최소 예시 — docs/IWINV_SETUP.md 참고 ---
# APP_ENV=production
# STORAGE_PROVIDER=s3
# S3_BUCKET=topik-myanmar-photos
# S3_ACCESS_KEY=...
# S3_SECRET=...
# MAIL_PROVIDER=smtp
# ENABLE_EMAIL_WORKER=true
# SMTP_USER=noreply@topik-myanmar.com
# SMTP_PASS=...

# Semantic search / RAG (V007 pgvector — embedding API는 후속 단계)
# SEMANTIC_SEARCH_ENABLED=false
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
