DATABASE_URL=postgresql+asyncpg://topik_app:change_me@127.0.0.1:5432/topik_myanmar
JWT_SECRET=change-this-to-a-long-random-secret
CORS_ORIGINS=http://localhost:5173

# File / photo storage — provider = local (dev: disk) | s3
# local (default): decoded photos saved on disk (ephemeral on VPS redeploy).
# s3: IwinV Object Storage (S3-compatible, docs/IWINV_SETUP.md §5). No AWS account required.
# STORAGE_PROVIDER=local
# UPLOAD_DIR=var/uploads
# S3 (when STORAGE_PROVIDER=s3): IwinV endpoint kr.object.iwinv.kr, region kr-standard
# S3_BUCKET=topik-myanmar-photos
# S3_REGION=kr-standard
# S3_ACCESS_KEY=
# S3_SECRET=
# S3_ENDPOINT=https://kr.object.iwinv.kr
# S3_PREFIX=photos
